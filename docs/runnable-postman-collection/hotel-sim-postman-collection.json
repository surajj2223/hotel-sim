		{
			"name": "04 · Payment lifecycle (real payments-sim webhooks)",
			"description": "The full money loop, driven by **real** sim triggers. core-api requests; the sim authorises/captures/refunds and fires its own signed webhook back. State is read from core-api after each webhook lands. One `pspReference`, sim-owned end to end.",
			"item": [
				{
					"name": "1 · API-008 · Create payment link (MANUAL, gated)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Human-Auth",
								"value": "{{humanAuthToken}}"
							}
						],
						"description": "core-api tx1 persists a PENDING payment + calls payments-sim (PSP-001) to mint paymentLinkId; tx2 stamps it. pspReference is null until the AUTHORISATION webhook.",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 18000,\n  \"currency\": \"GBP\",\n  \"captureMode\": \"MANUAL\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/bookings/{{bookingId}}/payments",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"bookings",
								"{{bookingId}}",
								"payments"
							]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('201 created', () => pm.response.to.have.status(201));",
									"const p = pm.response.json();",
									"pm.test('paymentLinkId minted by PSP', () => pm.expect(p.paymentLinkId).to.be.a('string').and.not.empty);",
									"pm.test('pspReference null pre-auth', () => pm.expect(p.pspReference).to.be.null);",
									"pm.collectionVariables.set('paymentId', p.id);",
									"pm.collectionVariables.set('merchantReference', p.merchantReference);",
									"pm.collectionVariables.set('paymentLinkId', p.paymentLinkId);",
									"pm.collectionVariables.set('amountRequested', String(p.amountRequested));",
									"// Clear any stale reference so nothing downstream can run on a leftover value.",
									"pm.collectionVariables.set('pspReference', '');"
								]
							}
						}
					]
				},
				{
					"name": "2 · [SIM] Authorise the link (real webhook fires)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"description": "payments-sim authorises, mints pspReference, and (sync) posts the signed AUTHORISATION webhook to core-api inline. /v1/test needs no X-PSP-Api-Key.",
						"body": {
							"mode": "raw",
							"raw": "{}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{pspBaseUrl}}/v1/test/payment-links/{{paymentLinkId}}/authorise?sync=true",
							"host": [
								"{{pspBaseUrl}}"
							],
							"path": [
								"v1",
								"test",
								"payment-links",
								"{{paymentLinkId}}",
								"authorise"
							],
							"query": [
								{
									"key": "sync",
									"value": "true"
								}
							]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('200 (sync) authorised', () => pm.response.to.have.status(200));",
									"const r = pm.response.json();",
									"pm.test('sim minted base62 pspReference', () => pm.expect(r.pspReference).to.match(/^PSP-[0-9A-Za-z]{16}$/));",
									"// Authoritative capture of pspReference happens in step 3 from core-api's",
									"// stamped state, which proves the webhook actually landed."
								]
							}
						}
					]
				},
				{
					"name": "3 · API-009 · Get payment (expect AUTHORISED)",
					"request": {
						"method": "GET",
						"header": [],
						"description": "Proves the AUTHORISATION webhook landed and transitioned core-api, and captures the single authoritative pspReference for all downstream steps.",
						"url": {
							"raw": "{{baseUrl}}/payments/{{paymentId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"payments",
								"{{paymentId}}"
							]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('200', () => pm.response.to.have.status(200));",
									"const p = pm.response.json();",
									"pm.test('status AUTHORISED after real webhook', () => pm.expect(p.status).to.eql('AUTHORISED'));",
									"pm.test('pspReference stamped by the webhook', () => pm.expect(p.pspReference).to.match(/^PSP-[0-9A-Za-z]{16}$/));",
									"// Use the reference core-api PERSISTED — exactly what it will send the sim on",
									"// capture/cancel/refund. There is only ever this one value.",
									"pm.collectionVariables.set('pspReference', p.pspReference);"
								]
							}
						}
					]
				},
				{
					"name": "4 · API-010 · Request capture (gated, 202)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Human-Auth",
								"value": "{{humanAuthToken}}"
							}
						],
						"description": "core-api validates + calls payments-sim (PSP-002) to QUEUE capture. No state change yet — the CAPTURE webhook (next step) is authoritative.",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": 18000\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/payments/{{paymentId}}/capture",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"payments",
								"{{paymentId}}",
								"capture"
							]
						}
					},
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const ref = pm.collectionVariables.get('pspReference') || '';",
									"if (!/^PSP-[0-9A-Za-z]{16}$/.test(ref)) {",
									"  throw new Error('pspReference \"' + ref + '\" not sim-minted — run steps 2-3 first on the smoke profile.');",
									"}"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('202 accepted (async request)', () => pm.response.to.have.status(202));"
								]
							}
						}
					]
				},
				{
					"name": "5 · [SIM] Settle capture (real webhook → revenue posts)",
					"request": {
						"method": "POST",
						"header": [],
						"description": "payments-sim fires the CAPTURE webhook to core-api; on receipt core-api posts REVENUE to the ledger (capture, not auth, is the revenue event).",
						"url": {
							"raw": "{{pspBaseUrl}}/v1/test/payments/{{pspReference}}/capture?sync=true",
							"host": [
								"{{pspBaseUrl}}"
							],
							"path": [
								"v1",
								"test",
								"payments",
								"{{pspReference}}",
								"capture"
							],
							"query": [
								{
									"key": "sync",
									"value": "true"
								}
							]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('200 (sync) capture dispatched', () => pm.response.to.have.status(200));"
								]
							}
						}
					]
				},
				{
					"name": "6 · API-009 · Get payment (expect CAPTURED)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/payments/{{paymentId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"payments",
								"{{paymentId}}"
							]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('200', () => pm.response.to.have.status(200));",
									"const p = pm.response.json();",
									"pm.test('status CAPTURED', () => pm.expect(p.status).to.eql('CAPTURED'));"
								]
							}
						}
					]
				},
				{
					"name": "7 · API-012 · Request refund (gated, 202)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Human-Auth",
								"value": "{{humanAuthToken}}"
							}
						],
						"description": "core-api persists a PENDING child refund (minting its own merchantReference, chaining originalReference → parent pspReference) and calls payments-sim (PSP-004) to queue the REFUND webhook.",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"amount\": {{refundAmount}},\n  \"reason\": \"guest goodwill — partial refund\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/payments/{{paymentId}}/refunds",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"payments",
								"{{paymentId}}",
								"refunds"
