    {
      "name": "05 · PROOF — scoped allocation landed on the spa line only",
      "item": [
        {
          "name": "1 · Get folio — spa settled, room still just held",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "const f = pm.response.json();",
                  "const room = f.lines.find(l => l.id === pm.collectionVariables.get('roomLineId'));",
                  "const spa  = f.lines.find(l => l.id === pm.collectionVariables.get('spaLineId'));",
                  "",
                  "// THE PROOF: spa revenue went to the SPA line, not the room line that sorts first.",
                  "pm.test('SPA line revenuePosted == 8000 (settled)', () => pm.expect(spa.revenuePosted).to.eql(8000));",
                  "pm.test('ROOM line revenuePosted == 0 (held auth, not captured)', () => pm.expect(room.revenuePosted).to.eql(0));",
                  "",
                  "// Folio rollups corroborate.",
                  "pm.test('amountPaid == 8000 (only the spa captured)', () => pm.expect(f.amountPaid).to.eql(8000));",
                  "pm.test('amountAuthorised == 54000 (room hold intact)', () => pm.expect(f.amountAuthorised).to.eql(54000));",
                  "pm.test('balance == 54000 (room still owed)', () => pm.expect(f.balance).to.eql(54000));",
                  "pm.test('booking still CONFIRMED (no completion yet)', () => pm.expect(f.status).to.eql('CONFIRMED'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
