    {
      "name": "02 · Room on a held auth (MANUAL, never captured here)",
      "item": [
        {
          "name": "1 · Create ROOM payment link (MANUAL, scoped to room line)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const p = pm.response.json();",
                  "pm.test('captureMode MANUAL', () => pm.expect(p.captureMode).to.eql('MANUAL'));",
                  "pm.test('paymentLinkId minted by PSP', () => pm.expect(p.paymentLinkId).to.be.a('string').and.not.empty);",
                  "pm.test('pspReference null pre-auth', () => pm.expect(p.pspReference).to.be.null);",
                  "pm.collectionVariables.set('roomPaymentId', p.id);",
                  "pm.collectionVariables.set('roomPaymentLinkId', p.paymentLinkId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Human-Auth", "value": "{{humanAuthToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 54000,\n  \"currency\": \"GBP\",\n  \"captureMode\": \"MANUAL\",\n  \"lineCoverage\": [\n    { \"bookingLineId\": \"{{roomLineId}}\", \"amount\": 54000 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings/{{bookingId}}/payments",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "{{bookingId}}", "payments"]
            }
          }
        },
